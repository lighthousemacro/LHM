# Pharos configuration. Copy to Pharos/.env and fill in. NEVER commit .env.

# Required. Signs the session cookie. Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
PHAROS_SECRET_KEY=

# --- Access verification ---------------------------------------------------
# Sign-in is INSTANT: enter the email on your subscription, we confirm it is an
# active subscriber, and you are in (no password, no inbox round-trip).
#
# Two Stripe accounts, joined by the subscriber's EMAIL (Stripe will not merge
# accounts). An active subscription in EITHER account grants access. Use
# RESTRICTED, read-only keys (scope: Customers + Subscriptions, read).
#   1) the account behind your Substack publication:
PHAROS_STRIPE_API_KEY=
#   2) your main account, where direct Pharos signups subscribe:
PHAROS_STRIPE_API_KEY_DIRECT=
# Leave both blank to run on allowlist + paid-seed only (pre-Stripe testing).

# Where "Become a member" sends a non-subscriber. Set to the direct Pharos
# Stripe Payment Link / Checkout URL once it exists. Defaults to Substack.
PHAROS_JOIN_URL=https://research.lighthousemacro.com/subscribe

# Public base URL. Local dev default below; in production set
# https://pharos.lighthousemacro.com
PHAROS_BASE_URL=http://127.0.0.1:8800

# The running OpenBB FastAPI data backend.
PHAROS_OPENBB_BACKEND=http://127.0.0.1:6900

# Set to 1 in production (HTTPS) so the session cookie is Secure.
PHAROS_COOKIE_SECURE=0
