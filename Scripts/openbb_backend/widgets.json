    "type": "table",
    "endpoint": "latest",
    "gridData": { "w": 40, "h": 15 },
    "params": [
      { "type": "text", "paramName": "series_ids", "value": "DGS10,DGS2,VIXCLS,BAMLH0A0HYM2,MORTGAGE30US,RRPONTSYD,WALCL", "show": true, "label": "Series IDs" }
    ],
    "data": {
      "table": {
        "showAll": true,
        "columnsDefs": [
