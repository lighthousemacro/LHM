#!/usr/bin/env python3
"""
Standalone LHM Telegram bot — the single, dependable @LHMacroBot.

Polls Telegram itself (getUpdates long-poll) and answers reactive commands
directly off the DB (lhm_framework) and real price data (lhm_read / yfinance),
rendering the same branded charts/tables. No MCP bridge, so it never drops.

It is the SOLE poller of the bot token — Telegram allows one getUpdates consumer
per token, so the old MCP bridge (bun server.ts) must NOT be polling at the same
time (this process 409-backoffs if it is). Outbound-only scripts (lhmbot_push.py)
coexist fine.

Commands: /q TICKER · /read TICKER (+chart) · /scan T1 T2 … · /snapshot · /help.
A bare ticker is treated as /q. Replies only to allowlisted chats.

    python3 lhmbot_server.py            # run the daemon
    python3 lhmbot_server.py --selftest # exercise dispatch on real data, no Telegram
"""
from __future__ import annotations

import json
import sys
import time
import traceback
from pathlib import Path

import requests

DP = Path("/Users/bob/LHM/Scripts/data_pipeline")
sys.path.insert(0, str(DP))
sys.path.insert(0, "/Users/bob/LHM/Scripts/chart_generation")
import lhm_framework as fw  # noqa: E402
import lhm_read  # noqa: E402
from lhm_tape_read import build_tape_read_chart  # noqa: E402
from lhm_table import build_scan_table  # noqa: E402

ENV_PATH = DP / ".env"
ACCESS_PATH = Path.home() / ".claude/channels/telegram/access.json"
OFFSET_PATH = Path("/Users/bob/LHM/Data/lhmbot_offset.json")
OUT_DIR = Path("/Users/bob/LHM/Outputs/lhmbot")
TG = "https://api.telegram.org"
DEFAULT_CHAT = "7556962272"

HELP = ("<b>LHM desk</b>\n"
        "/q TICKER — quick read (price, trend, RS vs QAI, Z-RoC)\n"
        "/read TICKER — full read + branded chart\n"
        "/scan T1 T2 … — ranked table through the LHM lens\n"
        "/snapshot — live macro regime read\n"
        "Or just send a ticker for a quick read.")


def load_token() -> str:
    for line in ENV_PATH.read_text().splitlines():
        line = line.strip()
        if line.startswith("TELEGRAM_BOT_TOKEN="):
            return line.split("=", 1)[1].strip()
    raise SystemExit("lhmbot_server: TELEGRAM_BOT_TOKEN missing in .env")


TOKEN = load_token()


def allowed_chats() -> set[str]:
    s: set[str] = set()
    try:
        a = json.loads(ACCESS_PATH.read_text())
        s = {str(x) for x in a.get("allowFrom", [])}
    except Exception:
        pass
    s.add(DEFAULT_CHAT)
    return s


ALLOWED = allowed_chats()


# --------------------------------------------------------------------------- #
# Telegram I/O
# --------------------------------------------------------------------------- #
def _api(method: str, **kw):
    return requests.post(f"{TG}/bot{TOKEN}/{method}", **kw)


def send(chat: str, text: str) -> None:
    if len(text) > 4096:
        text = text[:4050] + "\n\n[truncated]"
    _api("sendMessage", data={"chat_id": chat, "text": text, "parse_mode": "HTML",
                              "disable_web_page_preview": "true"}, timeout=30)


def send_photo(chat: str, path: str, caption: str = "") -> None:
    with open(path, "rb") as fh:
        _api("sendPhoto", data={"chat_id": chat, "caption": caption[:1024],
                                "parse_mode": "HTML"},
             files={"photo": (Path(path).name, fh, "image/png")}, timeout=120)


def typing(chat: str) -> None:
    try:
        _api("sendChatAction", data={"chat_id": chat, "action": "typing"}, timeout=10)
    except Exception:
        pass


# --------------------------------------------------------------------------- #
# Formatting
# --------------------------------------------------------------------------- #
def fmt_trend(r: dict) -> str:
    v200, v50 = r.get("vs200"), r.get("vs50")
    if v200 is None:
        return "trend n/a"
    if v200 < 0:
        return "below 200d"
    if v50 is not None and v50 < 0:
        return "below 50d, above 200d"
    return "above 50d & 200d"


def fmt_q(r: dict | None) -> str:
    if not r:
        return "Couldn't pull that ticker. Check the symbol."
    if r.get("error"):
        return f"{r['ticker']}: {r['error']}."
    z = r.get("zroc")
    ztxt = ("broken (&lt;-1.0)" if (z is not None and z < -1.0)
            else (f"{z:+.2f}" if z is not None else "n/a"))
    lines = [f"<b>{r['ticker']}</b> {r['last']:,.2f}  ({r['day_chg']:+.1f}%)",
             f"Trend: {fmt_trend(r)}.",
             f"RS vs QAI: {r['rs']}. Z-RoC: {ztxt}."]
    if r.get("stop"):
        lines.append(f"Binding stop ~{r['stop']:,.2f} (1% under the 200d).")
    return "\n".join(lines)


# --------------------------------------------------------------------------- #
# Dispatch
# --------------------------------------------------------------------------- #
def handle(msg: dict) -> None:
    chat = str(msg.get("chat", {}).get("id"))
    if chat not in ALLOWED:
        return
    text = (msg.get("text") or "").strip()
    if not text:
        return
    parts = text.split()
    cmd = parts[0].lower().lstrip("/").split("@")[0]
    args = [p.upper() for p in parts[1:]]

    try:
        if cmd in ("start", "help"):
            send(chat, HELP)
        elif cmd == "snapshot":
            send(chat, fw.format_snapshot_html())
        elif cmd in ("q", "read"):
            if not args:
                send(chat, f"Usage: /{cmd} TICKER")
                return
            typing(chat)
            r = lhm_read.read_symbol(args[0])
            if cmd == "q" or not r or r.get("error"):
                send(chat, fmt_q(r))
            else:
                cap = fmt_q(r)
                try:
                    png = build_tape_read_chart(
                        r["ticker"], r["px_df"], benchmark_df=r["bench_df"],
                        out_path=str(OUT_DIR / f"read_{r['ticker']}.png"))
                    send_photo(chat, png, cap)
                except Exception:
                    sys.stderr.write(traceback.format_exc())
                    send(chat, cap)
        elif cmd == "scan":
            if not args:
                send(chat, "Usage: /scan NVDA AAPL MSFT")
                return
            typing(chat)
            rows = []
            for t in args[:12]:
                r = lhm_read.read_symbol(t)
                if r and not r.get("error"):
                    rows.append(lhm_read.scan_row(r))
            if not rows:
                send(chat, "Couldn't pull those tickers.")
                return
            # LHM lens: leaders above their 200d rank first.
            rows.sort(key=lambda x: (0 if x["rs"] == "LEADING" else 1 if x["rs"] == "MIXED" else 2,
                                     -(x["vs200"] if x["vs200"] is not None else -999)))
            png = build_scan_table(rows, subtitle="Ranked through the LHM lens",
                                   out_path=str(OUT_DIR / "scan.png"))
            send_photo(chat, png, "LHM scan")
        elif len(parts) == 1 and text.replace(".", "").replace("-", "").isalnum() and len(text) <= 6:
            typing(chat)
            send(chat, fmt_q(lhm_read.read_symbol(text)))
        else:
            send(chat, HELP)
    except Exception:
        sys.stderr.write(traceback.format_exc())
        send(chat, "Hit an error on that one. Try again in a moment.")


# --------------------------------------------------------------------------- #
# Loop
# --------------------------------------------------------------------------- #
def _load_offset():
    try:
        return json.loads(OFFSET_PATH.read_text()).get("offset")
    except Exception:
        return None


def _save_offset(o) -> None:
    try:
        OFFSET_PATH.write_text(json.dumps({"offset": o}))
    except Exception:
        pass


def main() -> None:
    global ALLOWED
    ALLOWED = allowed_chats()
    sys.stderr.write(f"lhmbot_server: online, allowed={sorted(ALLOWED)}\n")
    sys.stderr.flush()
    offset = _load_offset()
    if offset is None:
        # Skip any backlog so we only answer messages sent after we come online.
        try:
            r = _api("getUpdates", data={"offset": -1, "timeout": 0}, timeout=20)
            res = r.json().get("result", []) if r.ok else []
            if res:
                offset = res[-1]["update_id"] + 1
                _save_offset(offset)
                sys.stderr.write(f"drained backlog; starting at offset {offset}\n")
                sys.stderr.flush()
        except Exception:
            pass
    backoff = 1
    while True:
        try:
            data = {"timeout": 30}
            if offset:
                data["offset"] = offset
            r = _api("getUpdates", data=data, timeout=40)
            if r.status_code == 409:
                backoff = min(backoff * 2, 30)
                sys.stderr.write(f"getUpdates 409 (another poller holds the token); "
                                 f"retry in {backoff}s\n")
                sys.stderr.flush()
                time.sleep(backoff)
                continue
            r.raise_for_status()
            backoff = 1
            ALLOWED = allowed_chats()
            for u in r.json().get("result", []):
                offset = u["update_id"] + 1
                _save_offset(offset)
                msg = u.get("message") or u.get("edited_message")
                if msg:
                    handle(msg)
        except requests.exceptions.RequestException as e:
            sys.stderr.write(f"net error: {e}\n")
            time.sleep(min(backoff * 2, 15))
            backoff = min(backoff * 2, 15)
        except Exception:
            sys.stderr.write(traceback.format_exc())
            time.sleep(3)


def _selftest() -> None:
    """Exercise dispatch on REAL data with Telegram stubbed out."""
    global ALLOWED, send, send_photo, typing
    ALLOWED = {"1"}
    out: list = []
    send = lambda c, t: out.append(("MSG", t))            # noqa: E731
    send_photo = lambda c, p, caption="": out.append(("PHOTO", p, caption))  # noqa: E731
    typing = lambda c: None                                # noqa: E731
    for t in ["/help", "/q NVDA", "/read NVDA", "/scan NVDA AAPL TLT", "/snapshot", "NVDA", "garbage here"]:
        out.clear()
        handle({"chat": {"id": 1}, "text": t})
        print(f"\n=== {t} ===")
        for o in out:
            if o[0] == "MSG":
                print("MSG:", o[1][:300])
            else:
                print("PHOTO:", o[1], "| caption:", o[2][:160])


if __name__ == "__main__":
    if "--selftest" in sys.argv:
        _selftest()
    else:
        main()
