  "lhm_engine_summary": {
    "name": "Engines — Mean |z| Summary",
    "description": "Per-engine summary of pillar composite z-scores. Mean, mean |z|, and max |z| across the pillars in each engine. The fastest read on which engine is doing the work.",
    "category": "Lighthouse Macro",
    "subCategory": "Synthesis",
    "type": "table",
    "endpoint": "engine_summary",
    "gridData": { "w": 30, "h": 12 },
    "data": {
      "table": {
        "showAll": true,
        "columnsDefs": [
          { "field": "engine", "headerName": "Engine", "cellDataType": "text", "pinned": "left", "width": 200 },
          { "field": "pillars_n", "headerName": "Pillars", "cellDataType": "number", "width": 90 },
          { "field": "mean_z", "headerName": "Mean z", "cellDataType": "number", "width": 100 },
          { "field": "mean_abs_z", "headerName": "Mean |z|", "cellDataType": "number", "width": 100 },
          { "field": "max_abs_z", "headerName": "Max |z|", "cellDataType": "number", "width": 100 }
        ]
