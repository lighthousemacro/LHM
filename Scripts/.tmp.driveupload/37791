    # Panel A: SPY vs MAs
    ax = axes[0, 0]
    ax.plot(spx_p.index, spx_p, color=THEME['primary'], linewidth=2.0, label='S&P 500')
    ax.plot(ma50_p.index, ma50_p, color=COLORS['dusk'], linewidth=1.2,
            linestyle='--', label='50d MA')
    ax.plot(ma200_p.index, ma200_p, color=COLORS['port'], linewidth=1.2, label='200d MA')
    style_ax(ax)
    ax.tick_params(axis='both', which='both', length=0)
    ax.yaxis.set_major_formatter(FuncFormatter(lambda x, p: f'{x:,.0f}'))
    ax.set_title('Trend: Reclaimed', fontsize=11, fontweight='bold', color=THEME['fg'])
    ax.legend(loc='lower left', fontsize=8, **legend_style())
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b'))
    if len(spx_p) > 0:
        add_last_value_label(ax, spx_p, color=THEME['primary'], fmt='{:,.0f}',
                             side='right', fontsize=8)

    # Panel B: Z-RoC
    ax = axes[0, 1]
    ax.plot(z_roc_p.index, z_roc_p, color=THEME['primary'], linewidth=2.0)
    ax.axhline(0, color=COLORS['fog'], linestyle='--', linewidth=0.8)
    ax.axhline(-1.0, color=COLORS['port'], linestyle='--', linewidth=0.8, alpha=0.6)
    ax.axhline(-1.5, color=COLORS['port'], linestyle='-', linewidth=0.8, alpha=0.6)
    style_ax(ax)
    ax.tick_params(axis='both', which='both', length=0)
    ax.set_title('Momentum: Recovering', fontsize=11, fontweight='bold', color=THEME['fg'])
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b'))
    if len(z_roc_p) > 0:
        add_last_value_label(ax, z_roc_p, color=THEME['primary'], fmt='{:.2f}',
                             side='right', fontsize=8)

    # Panel C: % Above 50d
    ax = axes[1, 0]
    ax.plot(pct50.index, pct50, color=THEME['primary'], linewidth=2.0)
    ax.axhline(35, color=COLORS['dusk'], linestyle='--', linewidth=0.8, alpha=0.6)
    ax.axhline(70, color=COLORS['starboard'], linestyle='--', linewidth=0.8, alpha=0.6)
    ax.set_ylim(0, 100)
    style_ax(ax)
    ax.tick_params(axis='both', which='both', length=0)
    ax.yaxis.set_major_formatter(FuncFormatter(lambda x, p: f'{x:.0f}%'))
    ax.set_title('Breadth: Thrust Watch', fontsize=11, fontweight='bold', color=THEME['fg'])
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b'))
    if len(pct50) > 0:
        add_last_value_label(ax, pct50, color=THEME['primary'], fmt='{:.0f}%',
                             side='right', fontsize=8)

    # Panel D: VIX
    ax = axes[1, 1]
    ax.plot(vix_p.index, vix_p, color=COLORS['venus'], linewidth=2.0)
    ax.axhline(20, color=COLORS['sea'], linestyle='--', linewidth=0.8, alpha=0.6)
    ax.axhline(30, color=COLORS['port'], linestyle='--', linewidth=0.8, alpha=0.6)
    ax.text(vix_p.index[max(0, len(vix_p)//10)], 21, 'Complacency', fontsize=8,
            color=COLORS['sea'])
    ax.text(vix_p.index[max(0, len(vix_p)//10)], 31, 'Fear', fontsize=8,
            color=COLORS['port'])
    style_ax(ax)
    ax.tick_params(axis='both', which='both', length=0)
    ax.set_title('Volatility: Fear Unwind', fontsize=11, fontweight='bold', color=THEME['fg'])
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b'))
    if len(vix_p) > 0:
        add_last_value_label(ax, vix_p, color=COLORS['venus'], fmt='{:.1f}',
                             side='right', fontsize=8)

    # Determine latest data date across all series
    latest_dates = []
    for s in [spx_p, z_roc_p, pct50, vix_p]:
        if len(s) > 0:
            latest_dates.append(s.index[-1])
    data_date = max(latest_dates) if latest_dates else datetime.now()

    brand_fig(fig, 'Where We Stand: The Structural Dashboard',
              subtitle='Figure 12: Trend, Momentum, Breadth, Volatility',
              source='S&P 500, CBOE, Lighthouse Macro calculations',
              data_date=data_date)
    save_fig(fig, 'pillar_11_fig_12.png')


