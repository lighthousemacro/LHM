# CHART 1: Z-RoC 63-Day with Regime Bands
# ============================================
def chart_01():
    """Z-RoC: Momentum Is the Early Warning System."""
    print('\nChart 1: Z-RoC 63-Day with Regime Bands...')

    # Try pre-computed first, fallback to computing from SPX
    z_roc = fetch_db_level('SPX_Z_RoC_63d')
    if len(z_roc) < 50:
        spx = fetch_db_level('SPX_Close')
        z_roc = compute_z_roc(spx, window=63, lookback=252)

    fig, ax = new_fig()

    ax.plot(z_roc.index, z_roc, color=THEME['primary'], linewidth=2.5, zorder=5)

    # Zero line
    ax.axhline(0, color=COLORS['fog'], linestyle='--', linewidth=1.0, zorder=2)

    # Regime bands
    ax.fill_between(z_roc.index, 1.0, 1.5, color=COLORS['sea'], alpha=0.08, zorder=1)
    ax.fill_between(z_roc.index, -1.0, -1.5, color=COLORS['port'], alpha=0.08, zorder=1)
    ax.fill_between(z_roc.index, 1.5, ax.get_ylim()[1] if ax.get_ylim()[1] > 1.5 else 3.0,
                    color=COLORS['starboard'], alpha=0.15, zorder=1)
    ax.fill_between(z_roc.index, -1.5, ax.get_ylim()[0] if ax.get_ylim()[0] < -1.5 else -3.0,
                    color=COLORS['port'], alpha=0.15, zorder=1)

    # Threshold labels
    ax.text(z_roc.index[-1] + pd.Timedelta(days=10), 1.0, '+1.0', fontsize=9,
            color=COLORS['sea'], fontweight='bold', va='center')
    ax.text(z_roc.index[-1] + pd.Timedelta(days=10), -1.0, '-1.0', fontsize=9,
            color=COLORS['port'], fontweight='bold', va='center')
    ax.text(z_roc.index[-1] + pd.Timedelta(days=10), 1.5, '+1.5', fontsize=9,
            color=COLORS['starboard'], fontweight='bold', va='center')
    ax.text(z_roc.index[-1] + pd.Timedelta(days=10), -1.5, '-1.5', fontsize=9,
            color=COLORS['port'], fontweight='bold', va='center')

    style_single_ax(ax, fmt='{:.1f}')
    set_xlim_to_data(ax, z_roc.index)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %Y'))
    add_last_value_label(ax, z_roc, color=THEME['primary'], fmt='{:.2f}', side='right')
    add_recessions(ax, start_date='2022-01-01')

    brand_fig(fig, 'Z-RoC: Momentum Is the Early Warning System',
              subtitle='Figure 1: 63-Day Standardized Rate of Change, S&P 500',
              source='S&P 500, Lighthouse Macro calculations',
              data_date=z_roc.index[-1])
    save_fig(fig, 'pillar_11_fig_01.png')


