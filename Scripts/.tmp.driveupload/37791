# COMPUTED SERIES HELPERS
# ============================================
def compute_z_roc(price, window=63, lookback=252):
    """Compute z-scored rate of change."""
    roc = price.pct_change(window) * 100
    z = (roc - roc.rolling(lookback).mean()) / roc.rolling(lookback).std()
    return z.dropna()


def compute_msi(spx, pct50, pct200, pct20, nh_nl, ad_line, mcclellan_sum):
    """Compute Market Structure Index from components."""
    # Align all series to common dates
    df = pd.DataFrame({
        'spx': spx,
        'pct50': pct50,
        'pct200': pct200,
        'pct20': pct20,
        'nh_nl': nh_nl,
        'ad_line': ad_line,
        'mcclellan': mcclellan_sum,
    }).dropna()

    if len(df) < 252:
        return pd.Series(dtype=float)

    # Compute components
    ma200 = df['spx'].rolling(200).mean()
    ma50 = df['spx'].rolling(50).mean()
    price_vs_200 = (df['spx'] / ma200 - 1) * 100
    price_vs_50 = (df['spx'] / ma50 - 1) * 100
    slope_50 = ma50.diff(10)  # 10-day change in 50d MA
    slope_20 = df['spx'].rolling(20).mean().diff(10)
    z_roc = compute_z_roc(df['spx'], window=63, lookback=252)
    nh_nl_20 = df['nh_nl'].rolling(20).mean()
    ad_slope = df['ad_line'].diff(20)

    # Z-score each component against 252-day rolling
    def zscore(s, lb=252):
        return (s - s.rolling(lb).mean()) / s.rolling(lb).std()

    components = pd.DataFrame({
        'price_200': zscore(price_vs_200),
        'price_50': zscore(price_vs_50),
        'slope_50': zscore(slope_50),
        'slope_20': zscore(slope_20),
        'z_roc': z_roc.reindex(df.index),
        'pct50': zscore(df['pct50']),
        'pct20': zscore(df['pct20']),
        'pct200': zscore(df['pct200']),
        'nh_nl': zscore(nh_nl_20),
        'ad_slope': zscore(ad_slope),
        'mcclellan': zscore(df['mcclellan']),
    }).dropna()

    weights = [0.15, 0.10, 0.10, 0.10, 0.12, 0.10, 0.08, 0.08, 0.07, 0.05, 0.05]
    msi = (components * weights).sum(axis=1)
    return msi


def compute_sbd(spx, pct50):
    """Compute Structure-Breadth Divergence."""
    ma200 = spx.rolling(200).mean()
    price_vs_200 = (spx / ma200 - 1) * 100

    def zscore(s, lb=252):
        return (s - s.rolling(lb).mean()) / s.rolling(lb).std()

    z_price = zscore(price_vs_200)
    z_breadth = zscore(pct50)
    sbd = (z_price - z_breadth).dropna()
    return sbd


